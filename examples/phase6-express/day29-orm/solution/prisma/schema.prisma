generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Todo 모델 정의
model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  done      Boolean  @default(false)
  priority  String   @default("medium")
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
